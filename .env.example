# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Resend (emails)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@firmiu.com

# App
NEXT_PUBLIC_APP_URL=https://firmiu.com
NEXT_PUBLIC_SITE_URL=https://firmiu.com

# Paddle (payments)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your-paddle-client-token
NEXT_PUBLIC_PADDLE_ENV=sandbox
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
NEXT_PUBLIC_PADDLE_PRICE_STARTER=pri_your_starter_price_id
NEXT_PUBLIC_PADDLE_PRICE_PRO=pri_your_pro_price_id
NEXT_PUBLIC_PADDLE_PRICE_BUSINESS=pri_your_business_price_id

# Cron
CRON_SECRET=your-cron-secret
